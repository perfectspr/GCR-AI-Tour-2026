# Azure AI Foundry Configuration
# Copy this file to .env and fill in your values

# Azure AI Project Endpoint
# Get this from Azure AI Foundry portal -> Project Settings -> Project connection string
# Format: https://<your-project>.api.azureml.ms
AZURE_AI_PROJECT_ENDPOINT=https://your-project.api.azureml.ms

# Azure AI Model Deployment Name
# The name of your deployed model (e.g., gpt-4, gpt-35-turbo)
# Must match a model deployment in your Azure AI Foundry project
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4

# Optional: Azure Subscription ID
# Only needed if you have multiple subscriptions
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# Optional: Azure Resource Group
# The resource group containing your AI Foundry project
# AZURE_RESOURCE_GROUP=your-resource-group

# Optional: Azure AI Project Name
# The name of your AI Foundry project
# AZURE_AI_PROJECT_NAME=your-project-name

# Alternative: Use Azure OpenAI directly (if not using AI Foundry)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional: For TTS and other features
# AZURE_SPEECH_KEY=your-speech-key
# AZURE_SPEECH_REGION=eastus

# Optional: For web search tool
# TAVILY_API_KEY=your-tavily-api-key
